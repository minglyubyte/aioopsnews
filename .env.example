# Shared project configuration
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/ai_reality_check
ADMIN_API_TOKEN=change-me-for-local-admin-access
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-supabase-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key

# LLM providers
OPENAI_API_KEY=your-openai-api-key
DEEPSEEK_API_KEY=your-deepseek-api-key
PRIMARY_REVIEW_BASE_URL=https://api.deepseek.com/v1
PRIMARY_REVIEW_MODEL=deepseek-v4-flash
ESCALATION_REVIEW_MODEL=deepseek-v4-pro
REVIEW_CONCURRENCY=10

# Scraping and ingestion
SCRAPER_USER_AGENT=ai-reality-check-bot/0.1
SCRAPER_TIMEOUT_SECONDS=20
SCRAPER_MAX_ARTICLES_PER_RUN=25
